# ====================================
# Student Management System - Environment Variables
# ====================================

# NODE_ENV: development, staging, or production
NODE_ENV=development

# ====================================
# SERVER CONFIGURATION
# ====================================
PORT=5000
FRONTEND_URL=http://localhost:5173

# ====================================
# DATABASE (MongoDB)
# ====================================

# For local development with in-memory MongoDB
# MONGO_URI=mongodb://localhost:27017/student-db

# For MongoDB Atlas (Production)
# Get connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/student-db
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/student-db

# ====================================
# AUTHENTICATION
# ====================================

# JWT Secret Key - Generate with: openssl rand -hex 32
# NEVER commit real secrets to git!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ====================================
# CLOUDINARY (File Uploads)
# ====================================

# Get credentials from: https://cloudinary.com/console
# Steps to setup:
# 1. Create account at cloudinary.com
# 2. Go to Dashboard/Settings
# 3. Copy API credentials

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ====================================
# UPLOAD RETRY CONFIGURATION
# ====================================

# Maximum retry attempts for failed uploads
UPLOAD_MAX_RETRIES=3

# Base delay in milliseconds (exponential backoff)
UPLOAD_BASE_DELAY=1000

# ====================================
# SOCKET.IO (Real-time Communication)
# ====================================

# CORS origins for WebSocket connections (comma-separated)
# Development: include localhost ports
# Production: include your Render domain
SOCKET_CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost,https://yourdomain.render.com

# ====================================
# LOGGING
# ====================================

# Log levels: DEBUG, INFO, WARN, ERROR, FATAL
LOG_LEVEL=INFO

# ====================================
# DEPLOYMENT (Render specific)
# ====================================

# Render creates this automatically, but you can override
# RENDER_EXTERNAL_URL=https://student-management-backend.render.com

# ====================================
# DEVELOPMENT HINTS
# ====================================

# 1. Copy this file to .env and fill in values:
#    cp .env.example .env
#
# 2. Install dependencies:
#    npm install
#
# 3. Start development server:
#    npm run dev
#
# 4. For Docker:
#    docker-compose up --build
#
# 5. For production deployment on Render:
#    - Create Web Service
#    - Connect GitHub repo
#    - Set environment variables
#    - Deploy!
